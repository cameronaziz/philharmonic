{
  "_schema": {
    "description": "Job postings discovered from ATS polling.",
    "fields": {
      "company_name": "string",
      "external_id": "string \u2014 ATS job ID",
      "title": "string",
      "url": "string \u2014 direct ATS posting URL",
      "location": "string",
      "remote_status": "remote | hybrid | onsite | unknown",
      "comp_base_min": "number",
      "comp_base_max": "number",
      "posted_at": "ISO date",
      "first_seen_at": "ISO timestamp",
      "last_seen_at": "ISO timestamp",
      "status": "open | closed",
      "passes_title_filter": "boolean",
      "passes_comp_filter": "boolean",
      "passes_mode_filter": "boolean",
      "fit_score": "number 0-100",
      "effective_score": "number \u2014 fit_score \u00d7 age_decay \u00d7 location_multiplier \u00d7 preference_multiplier",
      "age_decay": "number",
      "location_multiplier": "number",
      "preference_multiplier": "number",
      "pipeline_state": "discovered | scored | awaiting_approval | tailoring | submitted | rejected",
      "reasoning": "string",
      "verdict": "strong_match | good_match | borderline | poor_match"
    }
  },
  "rows": []
}