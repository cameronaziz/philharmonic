      "source": "seed | builtin | yc | wellfound | remoteok | wwr | manual",
      "has_remote_history": "boolean \u2014 true if any remote job ever seen",
      "user_rank_score": "number 0-1.30 \u2014 set by /rank command",
      "user_blacklisted": "boolean \u2014 BAD companies from /rank",
      "last_polled_at": "ISO timestamp",
      "consecutive_failures": "integer",
      "notes": "string \u2014 freeform notes"
    }
  },
